{
  "permissions": {
    "allow": [
      "Bash",
      "PowerShell",
      "Python",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "mcp__ide__executeCode",
      "mcp__ide__getDiagnostics",
      "mcp__knowledge__memory_recall",
      "mcp__knowledge__memory_get",
      "mcp__knowledge__memory_upsert",
      "mcp__knowledge__memory_mark"
    ],
    "deny": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\knowledge-capture-stop.ps1\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "model": "haiku"
}
