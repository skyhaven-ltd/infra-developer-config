{
  // --- Editor ---
  "editor.fontSize": 26,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.mouseWheelZoom": true,

  // --- Files ---
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.terraform": true,
    "**/.pytest_cache": true
  },

  // --- Explorer ---
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // --- Terminal ---
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.profiles.windows": {
    "Claude": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["-lc", "claude; exec bash"],
      "icon": "sparkle"
    },
    "Codex": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["-lc", "codex; exec bash"],
      "icon": "hubot"
    },
    "Git Bash": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "icon": "terminal-bash"
    }
  },
  "terminal.integrated.hideOnStartup": "never",

  // --- Git ---
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.pruneOnFetch": true,
  "git.openRepositoryInParentFolders": "never",

  // --- Workbench ---
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.colorTheme": "Dark Modern",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.panel.defaultLocation": "right",

  // --- Security ---
  "security.workspace.trust.untrustedFiles": "open",

  // --- Extensions ---
  "extensions.ignoreRecommendations": false,
  "githubPullRequests.pushBranch": "always",

  // --- Claude Code ---
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "opus",

  // --- Language: Terraform ---
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // --- Language: JSON/JSONC ---
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // --- Language: YAML ---
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.validate": true,

  // --- Language: Markdown ---
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": { "other": false }
  },

  // --- Language: Python ---
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },

  // --- Language: PowerShell ---
  "[powershell]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "ms-vscode.powershell"
  },

  // --- Language: Shell ---
  "[shellscript]": {
    "editor.tabSize": 2
  },
  "azureTerraform.survey": {
    "surveyPromptDate": "never",
    "surveyPromptIgnoredCount": 0
  }
}
